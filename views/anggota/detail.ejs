<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content">
  <div class="top-header">
    <div class="d-flex align-items-center">
      <a href="/anggota" class="btn btn-link p-0 me-3" style="color:var(--on-surface);">
        <span class="material-symbols-outlined">arrow_back</span>
      </a>
      <h1 class="page-title">Detail Anggota</h1>
    </div>
    <div class="d-flex gap-2">
      <% if (user.role === 'admin' || user.role === 'operator') { %>
        <a href="/anggota/edit/<%= anggota.id %>" class="btn btn-outline-warning">
          <span class="material-symbols-outlined me-1" style="font-size:1.125rem;vertical-align:middle;">edit</span> Edit
        </a>
      <% } %>
    </div>
  </div>

  <div class="content-wrapper">
    <div class="row">
      <div class="col-lg-4">
        <div class="card text-center mb-4 shadow-sm border-0">
          <div class="card-body py-5">
            <div class="mb-3">
              <div class="d-inline-flex align-items-center justify-content-center bg-danger text-white rounded-circle shadow-sm" style="width:100px; height:100px;">
                <span class="material-symbols-outlined" style="font-size:3.5rem;">person</span>
              </div>
            </div>
            <h4 class="mb-1"><%= anggota.nama_lengkap %></h4>
            <p class="text-muted mb-3">Anggota Koperasi</p>
            <span class="badge rounded-pill bg-success px-3 py-2">Aktif</span>
          </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
          <div class="card-body">
            <h6 class="card-title fw-bold mb-3">Kontak Cepat</h6>
            <div class="d-grid gap-2">
              <% 
                let waNumber = anggota.nomor_telepon;
                if(waNumber.startsWith('0')) {
                  waNumber = '62' + waNumber.substring(1);
                }
              %>
              <a href="https://wa.me/<%= waNumber %>" target="_blank" class="btn btn-success d-flex align-items-center justify-content-center">
                <span class="material-symbols-outlined me-2">chat</span> WhatsApp
              </a>
              <a href="tel:+<%= waNumber %>" class="btn btn-primary d-flex align-items-center justify-content-center">
                <span class="material-symbols-outlined me-2">call</span> Telepon
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-header bg-white py-3 border-0">
            <h5 class="mb-0 fw-bold">Informasi Lengkap</h5>
          </div>
          <div class="card-body">
            <div class="row mb-3">
              <div class="col-sm-4 text-muted">NIK (Nomor Induk Kependudukan)</div>
              <div class="col-sm-8 fw-bold"><%= anggota.nik %></div>
            </div>
            <hr class="text-muted opacity-25">
            <div class="row mb-3">
              <div class="col-sm-4 text-muted">Nama Lengkap</div>
              <div class="col-sm-8"><%= anggota.nama_lengkap %></div>
            </div>
            <hr class="text-muted opacity-25">
            <div class="row mb-3">
              <div class="col-sm-4 text-muted">Email</div>
              <div class="col-sm-8 text-primary"><%= anggota.email || '—' %></div>
            </div>
            <hr class="text-muted opacity-25">
            <div class="row mb-3">
              <div class="col-sm-4 text-muted">Nomor Telepon</div>
              <div class="col-sm-8"><%= anggota.nomor_telepon %></div>
            </div>
            <hr class="text-muted opacity-25">
            <div class="row mb-3">
              <div class="col-sm-4 text-muted">Tanggal Bergabung</div>
              <div class="col-sm-8"><%= new Date(anggota.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></div>
            </div>
            
            <div class="mt-5 p-3 bg-light rounded-3 border">
              <div class="d-flex align-items-center mb-2">
                <span class="material-symbols-outlined text-info me-2">info</span>
                <span class="fw-bold">Informasi Akun</span>
              </div>
              <p class="small text-muted mb-0">
                Anggota ini memiliki akses login ke sistem menggunakan <strong>Nama Depan (Max 5 Huruf)</strong> sebagai Username. Jika anggota lupa password, silakan hubungi Admin untuk melakukan reset password melalui Manajemen Pengguna.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
