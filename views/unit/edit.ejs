<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content">
  <div class="top-header">
    <div>
      <button class="btn btn-link d-lg-none p-0 me-3" onclick="toggleSidebar()" style="color:var(--on-surface);"><span class="material-symbols-outlined">menu</span></button>
      <h1 class="page-title d-inline-block">Edit Unit Usaha</h1>
    </div>
    <a href="/unit-usaha" class="btn btn-secondary">
      <span class="material-symbols-outlined me-1" style="font-size:1.125rem;vertical-align:middle;">arrow_back</span> Kembali
    </a>
  </div>
  <div class="content-wrapper">
    <div class="card" style="max-width:600px;">
      <div class="card-body">
        <form action="/unit-usaha/edit/<%= unit.id %>" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label for="nama_unit" class="form-label">Nama Unit Usaha <span style="color:var(--error);">*</span></label>
            <input type="text" class="form-control" id="nama_unit" name="nama_unit" value="<%= unit.nama_unit %>" required>
          </div>
          <div class="mb-3">
            <label for="penanggung_jawab" class="form-label">Penanggung Jawab</label>
            <input type="text" class="form-control" id="penanggung_jawab" name="penanggung_jawab" value="<%= unit.penanggung_jawab || '' %>" placeholder="Nama Penanggung Jawab">
          </div>
          <div class="mb-3">
            <label for="bidang_usaha" class="form-label">Bidang Usaha</label>
            <input type="text" class="form-control" id="bidang_usaha" name="bidang_usaha" value="<%= unit.bidang_usaha || '' %>" placeholder="Contoh: Perdagangan / Jasa / Pertanian">
          </div>
          <div class="mb-3">
            <label for="alamat" class="form-label">Alamat</label>
            <textarea class="form-control" id="alamat" name="alamat" rows="2" placeholder="Alamat lengkap unit usaha"><%= unit.alamat || '' %></textarea>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label for="pic" class="form-label">PIC (Person In Charge)</label>
              <input type="text" class="form-control" id="pic" name="pic" value="<%= unit.pic || '' %>" placeholder="Nama PIC">
            </div>
            <div class="col-md-6">
              <label for="no_hp_pic" class="form-label">Nomor HP PIC</label>
              <input type="text" class="form-control" id="no_hp_pic" name="no_hp_pic" value="<%= unit.no_hp_pic || '' %>" placeholder="Contoh: 081234567890">
            </div>
          </div>
          <div class="mb-4">
            <label for="deskripsi" class="form-label">Deskripsi</label>
            <textarea class="form-control" id="deskripsi" name="deskripsi" rows="3"><%= unit.deskripsi || '' %></textarea>
          </div>
          <button type="submit" class="btn btn-primary">
            <span class="material-symbols-outlined me-1" style="font-size:1.125rem;vertical-align:middle;">save</span> Perbarui
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
