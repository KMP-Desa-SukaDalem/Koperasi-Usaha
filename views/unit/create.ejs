<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content">
  <div class="top-header">
    <div>
      <button class="btn btn-link d-lg-none p-0 me-3" onclick="toggleSidebar()" style="color:var(--on-surface);"><span class="material-symbols-outlined">menu</span></button>
      <h1 class="page-title d-inline-block">Tambah Unit Usaha</h1>
    </div>
    <a href="/unit-usaha" class="btn btn-secondary">
      <span class="material-symbols-outlined me-1" style="font-size:1.125rem;vertical-align:middle;">arrow_back</span> Kembali
    </a>
  </div>
  <div class="content-wrapper">
    <div class="card" style="max-width:600px;">
      <div class="card-body">
        <form action="/unit-usaha" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label for="nama_unit" class="form-label">Nama Unit Usaha <span style="color:var(--error);">*</span></label>
            <input type="text" class="form-control" id="nama_unit" name="nama_unit" placeholder="Contoh: Toko Tani Lestari" required>
          </div>
          <div class="mb-4">
            <label for="deskripsi" class="form-label">Deskripsi</label>
            <textarea class="form-control" id="deskripsi" name="deskripsi" rows="3" placeholder="Deskripsi singkat unit usaha"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">
            <span class="material-symbols-outlined me-1" style="font-size:1.125rem;vertical-align:middle;">save</span> Simpan
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
